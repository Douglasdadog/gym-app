# ============================================
# Cyber-Gym Environment Variables
# Copy to .env.local for local development
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq AI - Multi-Key Rotation (5 keys). On 429 rate limit, auto-switches to next key.
GROQ_API_KEY_1=your-groq-api-key-1
GROQ_API_KEY_2=your-groq-api-key-2
GROQ_API_KEY_3=your-groq-api-key-3
GROQ_API_KEY_4=your-groq-api-key-4
GROQ_API_KEY_5=your-groq-api-key-5

# Grok AI (X.AI) - Required for Admin AI Business Analyst
# Get keys from https://console.x.ai/ - Add at least 1, up to 5 for rotation
GROK_API_KEY_1=your-grok-api-key-1
GROK_API_KEY_2=your-grok-api-key-2
GROK_API_KEY_3=your-grok-api-key-3
GROK_API_KEY_4=your-grok-api-key-4
GROK_API_KEY_5=your-grok-api-key-5

# Meta (Messenger / Instagram webhook)
META_VERIFY_TOKEN=your-webhook-verify-token
META_PAGE_ACCESS_TOKEN=your-page-access-token-for-messenger
# Optional: for scripts/get-long-lived-page-token.mjs (get 60-day token). From App Dashboard → Settings → Basic
# META_APP_ID=your-app-id
# META_APP_SECRET=your-app-secret
# Optional: Instagram DM replies. Leave empty to use META_PAGE_ACCESS_TOKEN for IG (works when Page is linked to Instagram in Business Suite)
META_IG_ACCESS_TOKEN=

# ManyChat -> app inbox sync (set in Vercel + ManyChat header x-manychat-secret)
MANYCHAT_WEBHOOK_SECRET=your-random-long-secret

# Optional: Travel fee per km for Home-based PT sessions
TRAVEL_FEE_PER_KM=2.50

# PayMongo (Philippines payment gateway: card, GCash, PayMaya, GrabPay, QR Ph)
# Get keys at https://dashboard.paymongo.com/ — create webhook for checkout_session.payment.paid → https://YOUR_DOMAIN/api/webhooks/paymongo
PAYMONGO_SECRET_KEY=sk_test_xxx
# Base URL for success/cancel redirects. Local: http://localhost:3000 | Vercel: https://gym-app-eight-psi.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
